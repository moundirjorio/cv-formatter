# Clé Anthropic (Claude) pour l'extraction du CV
ANTHROPIC_API_KEY=sk-ant-...
# Clés API acceptées par le service (séparées par des virgules)
CV_API_KEYS=dev-key-changeme
# Modèle Claude utilisé pour l'extraction
CLAUDE_MODEL=claude-opus-4-8
APP_ENV=development

# Connexion à l'interface web (studio). À CHANGER en production.
LOGIN_USER=admin
LOGIN_PASSWORD=changeme
# Secret de signature du cookie de session (HMAC). Mets une valeur longue et aléatoire.
SESSION_SECRET=dev-session-secret-change-me
# Durée d'une session (heures)
SESSION_HOURS=12

# Commercial Compleo par défaut (utilisé si le champ est laissé vide)
COMPLEO_COMMERCIAL_NAME=Taha NORDINE
COMPLEO_COMMERCIAL_EMAIL=t.nordine@compleotech.net
COMPLEO_COMMERCIAL_PHONE=+33603437383
